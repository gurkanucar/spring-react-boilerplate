# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# ==================== STORAGE ====================
# Which backend NEW uploads go to: FILESYSTEM | S3 | R2 (existing files resolve to wherever stored).
STORAGE_DEFAULT=FILESYSTEM

# Filesystem (enabled by default).
STORAGE_FILESYSTEM_ENABLED=true
STORAGE_FS_BASE_PATH=./uploads
STORAGE_FS_PUBLIC_URL=

# S3 / RustFS (registered only when enabled + bucket + keys set).
STORAGE_S3_ENABLED=true
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
# Path-style public base = <endpoint>/<bucket>. /files/:id/url returns base + key.
STORAGE_S3_PUBLIC_URL=

# Cloudflare R2 (registered only when enabled + bucket + keys + endpoint set).
STORAGE_R2_ENABLED=true
STORAGE_R2_BUCKET=
STORAGE_R2_ACCESS_KEY=
STORAGE_R2_SECRET_KEY=
STORAGE_R2_ENDPOINT=
STORAGE_R2_PUBLIC_URL=

# ==================== UPLOAD VALIDATION ====================
UPLOAD_MAX_BYTES=52428800
UPLOAD_DENY_EXT=.exe,.dll,.so,.sh,.bat,.cmd,.com,.msi,.scr,.ps1
UPLOAD_ALLOW_EXT=

# ==================== RABBITMQ ====================
# Scheduled/delayed-events example. `docker compose up -d rabbitmq` (management UI on :15672).
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
